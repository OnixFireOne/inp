# ============================================================
# inp.one v2 — шаблон переменных окружения
# Скопируй этот файл в .env.local и заполни значения.
#
# Правила:
#  - NEXT_PUBLIC_*  -> попадают в браузер (НЕ клади сюда секреты!)
#  - всё остальное   -> только на сервере, в клиент не попадает
#  - .env.local НИКОГДА не коммитить (должен быть в .gitignore)
#  - после любого изменения — перезапусти `npm run dev`
# ============================================================


# ---------- PHASE 2: цены и график ----------

# CoinGecko API (demo-ключ бесплатно на coingecko.com -> Developer Dashboard)
COINGECKO_API_KEY=
# demo: https://api.coingecko.com/api/v3   |   pro: https://pro-api.coingecko.com/api/v3
COINGECKO_BASE=https://api.coingecko.com/api/v3

# TTL кэша (секунды)
PRICE_TTL_SECONDS=20
SPARK_TTL_SECONDS=300

# Redis / KV для кэша цен и спарклайнов.
# Дев без Docker: возьми бесплатный Upstash Redis (REST).
# Можно оставить пустыми, если lib/kv.ts имеет no-op fallback (цены без кэша).
KV_REST_API_URL=
KV_REST_API_TOKEN=


# ---------- PHASE 3: аккаунты, watchlist, Web3 ----------

# Supabase (облачный проект: supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# СЕКРЕТ! только на сервере (seed, admin ops). RLS bypass.
SUPABASE_SECRET_KEY=

# WalletConnect (cloud.walletconnect.com -> Project)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Секрет для подписи SIWE nonce/сессии (сгенерируй случайную строку)
# например: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIWE_SESSION_SECRET=


# ---------- PHASE 6: ПОДДЕРЖКА КАТАЛОГА ИИ (позже) ----------

# LLM-ключи для ежемесячного поиска агрегаторов (несколько движков).
# Нужны только на Phase 6 — пока можно оставить пустыми.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# ---------- ШАБЛОНЫ ССЫЛОК: снимок CoinGecko ----------
# TTL снапшота asset_meta (по умолчанию 7 дней; ссылки меняются редко).
CG_META_TTL_DAYS=7
# TTL negative-cache при 404 от CG (по умолчанию 6 часов).
CG_META_NEG_TTL_SECONDS=21600
# Глобальный rate budget для /coins/{id} (default: 30 req / 60s, free CG).
CG_META_BUCKET_CAPACITY=30
CG_META_BUCKET_WINDOW_SECONDS=60


# ---------- ПРОЧЕЕ (опционально) ----------

# Базовый URL сайта (для redirect'ов, SSR-метаданных, deep-links).
# Дев: http://localhost:3000 ; Прод: https://inp.one
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Отключить телеметрию Next.js (или: npx next telemetry disable)
NEXT_TELEMETRY_DISABLED=1
